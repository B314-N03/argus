# Argus Environment Configuration
# Copy this file to .env.local and configure as needed

# Feature flags
VITE_USE_MOCK_DATA=true

# Aviation APIs
# Airplanes.live - free, no auth required
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=

# Naval APIs
# AISStream.io - free WebSocket API, register at https://aisstream.io
# AISSTREAM_API_KEY=

# News APIs
# ACLED - conflict data, free registration at https://acleddata.com
# ACLED_API_KEY=
# ACLED_EMAIL=

# Social Media
# Bluesky - free, no auth for public search
# Bluesky can be used without API keys
# For authenticated access:
# BLUESKY_IDENTIFIER=
# BLUESKY_APP_PASSWORD=

# Twitter/X - paid API ($200+/month)
# TWITTER_BEARER_TOKEN=
